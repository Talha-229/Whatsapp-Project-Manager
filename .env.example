# Copy to .env and fill in values

# Used to sign Google OAuth state cookies (required for Calendar linking). Any long random string.
SECRET_KEY=

# Supabase (required for persistence, policies, reminders)
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Postgres connection URI for LangGraph checkpointing (Supabase: Project Settings -> Database -> URI)
# Use Session mode (port 5432) or Transaction pooler; sslmode=require often required
DATABASE_URL=

# Meta WhatsApp Cloud API
META_WA_VERIFY_TOKEN=
META_WA_ACCESS_TOKEN=
META_WA_PHONE_NUMBER_ID=
META_WA_APP_SECRET=

# Public URL of this API (for Google OAuth links sent in WhatsApp)
PUBLIC_BASE_URL=https://your-ngrok-url.ngrok-free.app

# OpenAI (LLM + Whisper)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
WHISPER_MODEL=whisper-1

# Default IANA timezone for scheduling (e.g. Asia/Karachi, America/New_York)
DEFAULT_TZ=UTC

# Optional app tuning (defaults match app/config.py)
# APP_NAME=WhatsApp Agent API
# DEBUG=false
# LANGGRAPH_MAX_CLARIFY_TURNS=2

# Google OAuth (Calendar + Contacts)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://your-ngrok-url.ngrok-free.app/oauth/google/callback
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
GOOGLE_TOKEN_ENCRYPTION_KEY=

# Recall.ai (optional — meeting notetaker + Svix webhook)
RECALL_API_KEY=
RECALL_REGION=us-east-1
RECALL_BOT_NAME=WhatsApp Notetaker
RECALL_WEBHOOK_SECRET=
